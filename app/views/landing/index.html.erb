          </div>
          <div class="ship-card-name"><%= app[:name] %><span class="tld"><%= app[:tld] %></span></div>
          <div class="ship-card-tag"><%= app[:tag] %></div>
          <p class="ship-card-blurb"><%= app[:blurb] %></p>
