  <!-- ───────────────────────── SHIPPING ──────────────────────── -->
  <!-- Full apps list (live + closed). The hero highlights the live ones;
       this section is the comprehensive view, including the 5 retired apps. -->
  <section id="shipping" class="section reveal">
    <div class="section-label" style="color: var(--glow2);">$ ls ~/projects --all</div>
    <h2>Things I've shipped.</h2>
    <p class="section-sub">All 12 — what's live in production and what's been retired.</p>

    <!-- Mixed-span bento: 7 live SaaS apps. Each app's `span` field controls
         its size: wide (2×1), tall (1×2), small (1×1). Layout mirrors the
         Dribbble bento shot the user pointed at. -->
    <div class="ship-grid">
      <% live_apps.each do |app| %>
        <a href="<%= app[:url] %>" target="_blank" rel="noopener"
           class="ship-card span-<%= app[:span] || 'small' %>"
           style="--pc: <%= app[:color] %>;">
          <div class="ship-card-top">
            <span class="badge-live"><span class="ld"></span> Live</span>
            <span class="ship-arrow">
              <svg fill="none" stroke="currentColor" stroke-width="2.4" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M7 17L17 7M17 7H8M17 7v9"/></svg>
