<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    --bg: #0a0710;
    --text: #ebe7f5;
    --muted: rgba(235, 231, 245, 0.46);
    --line: rgba(255, 255, 255, 0.07);
    --line-strong: rgba(255, 255, 255, 0.15);
    --surface: rgba(255, 255, 255, 0.025);
    --glow1: #7c5cff;   /* purple — indie hacker */
    --glow2: #22d3ee;   /* cyan   — code/engineer */
    --glow3: #fb7185;   /* rose   — bug bounty */
    --glow4: #fbbf24;   /* amber  — warmth/now */
    --green: #34d399;
  }

  html { scroll-behavior: smooth; }
  body {
    background: var(--bg);
    color: var(--text);
    font-family: 'Lexend', ui-sans-serif, system-ui, -apple-system, sans-serif;
    -webkit-font-smoothing: antialiased;
    overflow-x: hidden;
    letter-spacing: -0.01em;
  }
  a { color: inherit; text-decoration: none; }
  code, .mono { font-family: 'JetBrains Mono', ui-monospace, SFMono-Regular, Menlo, monospace; }

  /* ── Animated background ────────────────────────────────────────────── */
  .bg-scene { position: fixed; inset: 0; pointer-events: none; z-index: 0; overflow: hidden; }
  .orb {
    position: absolute; border-radius: 50%; filter: blur(110px); opacity: 0.32;
    animation: orbFloat 14s ease-in-out infinite alternate;
  }
  .orb-1 { width: 620px; height: 620px; background: var(--glow1); top: -18%; left: -8%; animation-delay: 0s; }
  .orb-2 { width: 520px; height: 520px; background: var(--glow2); top: 18%; right: -10%; animation-delay: -4s; animation-duration: 17s; }
  .orb-3 { width: 420px; height: 420px; background: var(--glow3); bottom: 8%; left: 28%; animation-delay: -8s; animation-duration: 15s; }
  .orb-4 { width: 360px; height: 360px; background: var(--glow4); top: 58%; left: -6%; animation-delay: -2s; animation-duration: 19s; opacity: 0.22; }
  @keyframes orbFloat {
    0%   { transform: translate(0,0) scale(1); }
    33%  { transform: translate(40px,-30px) scale(1.08); }
    66%  { transform: translate(-22px,40px) scale(0.96); }
    100% { transform: translate(28px,18px) scale(1.04); }
  }
  .grain {
    position: fixed; inset: 0; pointer-events: none; z-index: 1; opacity: 0.035;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E");
    background-size: 128px;
  }

  .page { position: relative; z-index: 2; padding-bottom: 120px; }

  /* ── Floating pill nav ──────────────────────────────────────────────── */
  .nav {
    position: fixed; top: 16px; left: 50%; transform: translateX(-50%); z-index: 100;
    display: flex; align-items: center; justify-content: space-between; gap: 16px;
    width: 92%; max-width: 940px;
    padding: 12px 22px;
    background: rgba(10, 7, 16, 0.62);
    backdrop-filter: blur(20px); -webkit-backdrop-filter: blur(20px);
    border: 1px solid var(--line); border-radius: 999px;
  }
  .nav-brand {
    display: inline-flex; align-items: center; gap: 10px;
    font-size: 14px; font-weight: 700; letter-spacing: -0.02em;
    color: var(--text);
  }
  .nav-brand .name { color: var(--text); }
  .nav-brand .status-dot {
    width: 7px; height: 7px; border-radius: 50%;
    background: var(--green); box-shadow: 0 0 10px var(--green);
    animation: pulseDot 2.2s ease-in-out infinite;
  }
  .nav-links { display: flex; gap: 4px; }
  .nav-link {
    font-size: 13px; font-weight: 500; color: var(--muted);
    padding: 7px 14px; border-radius: 999px; transition: all 0.18s;
  }
  .nav-link:hover { color: var(--text); background: rgba(255, 255, 255, 0.05); }
  .nav-cta {
    font-size: 12px; font-weight: 700; letter-spacing: 0.04em; text-transform: uppercase;
    padding: 8px 16px; border-radius: 999px;
    color: #0a0710;
    background: linear-gradient(135deg, var(--glow1), var(--glow2));
    box-shadow: 0 0 24px rgba(124, 92, 255, 0.25);
    transition: all 0.2s;
  }
  .nav-cta:hover { transform: translateY(-1px); box-shadow: 0 0 32px rgba(124, 92, 255, 0.45); }
  @keyframes pulseDot { 0%,100% { opacity: 1; } 50% { opacity: 0.45; } }

  /* ── Hero: personal identity (photo, name, tagline, chips, socials) ── */
  .hero {
    padding: 110px 24px 50px;
    max-width: 820px; margin: 0 auto;
    text-align: center;
    display: flex; flex-direction: column; align-items: center;
  }
  /* Hero avatar with rotating conic-gradient ring */
  .hero-photo-wrap {
    position: relative; width: 88px; height: 88px;
    margin: 0 auto 20px;
    animation: fadeUp 0.7s 0.0s ease-out both;
  }
  .hero-photo-wrap::before {
    content: ""; position: absolute; inset: -6px; border-radius: 50%;
    background: conic-gradient(from 0deg,
      var(--glow1), var(--glow2), var(--glow3), var(--glow4), var(--glow1));
    opacity: 0.5; filter: blur(11px);
    animation: spin 20s linear infinite;
  }
  .hero-photo {
    position: relative; width: 100%; height: 100%; border-radius: 50%;
    object-fit: cover;
    border: 2px solid rgba(255,255,255,0.18);
    background: var(--bg);
    box-shadow: 0 8px 24px rgba(0,0,0,0.5);
  }
  .hero-photo-status {
    position: absolute; bottom: 2px; right: 2px; z-index: 2;
    width: 14px; height: 14px; border-radius: 50%;
    background: var(--green); border: 2.5px solid var(--bg);
    box-shadow: 0 0 8px var(--green);
  }
  .hero-eyebrow {
    display: inline-flex; align-items: center; gap: 7px;
    font-size: 10px; font-weight: 700; letter-spacing: 0.14em; text-transform: uppercase;
    color: var(--glow4);
    padding: 5px 13px; border-radius: 999px;
    border: 1px solid rgba(251, 191, 36, 0.22);
    background: rgba(251, 191, 36, 0.06);
    margin-bottom: 18px;
    animation: fadeUp 0.7s 0.06s ease-out both;
  }
  .hero-eyebrow .dot {
    width: 6px; height: 6px; border-radius: 50%;
    background: var(--glow4); box-shadow: 0 0 8px var(--glow4);
    animation: pulseDot 2s infinite ease-in-out;
  }
  .hero h1 {
    font-size: clamp(36px, 5.5vw, 58px); font-weight: 900;
    line-height: 1.02; letter-spacing: -0.035em;
    max-width: 720px; margin: 0 auto 16px;
    animation: fadeUp 0.8s 0.08s ease-out both;
  }
  /* Subtle dotted grid behind the hero — adds texture without competing */
  .hero::before {
    content: ""; position: absolute; inset: 0;
    background-image: radial-gradient(rgba(255,255,255,0.05) 1px, transparent 1px);
    background-size: 22px 22px;
    -webkit-mask-image: radial-gradient(ellipse 70% 55% at center, black 25%, transparent 75%);
    mask-image: radial-gradient(ellipse 70% 55% at center, black 25%, transparent 75%);
    pointer-events: none;
    z-index: 0;
  }
  .hero > * { position: relative; z-index: 1; }
  .hero { position: relative; }
  .hero h1 .gr {
    background: linear-gradient(135deg, var(--glow1) 0%, var(--glow2) 30%, var(--glow3) 60%, var(--glow4) 100%);
    background-size: 200% 200%;
    -webkit-background-clip: text; background-clip: text; color: transparent;
    animation: gradientShift 7s ease-in-out infinite;
  }
  @keyframes gradientShift {
    0%, 100% { background-position: 0% 50%; }
    50%      { background-position: 100% 50%; }
  }
  .hero-sub {
    font-size: clamp(14px, 1.7vw, 17px); color: var(--muted);
    max-width: 580px; line-height: 1.65; margin: 0 auto 26px;
    animation: fadeUp 0.8s 0.16s ease-out both;
  }
  .hero-sub strong { color: var(--text); font-weight: 600; }
  .hero-sub a { color: var(--text); border-bottom: 1px dashed rgba(255,255,255,0.25); }
  .hero-sub a:hover { border-color: var(--text); }

  /* Identity chips row */
  .hero-meta {
    display: flex; flex-wrap: wrap; gap: 6px; justify-content: center;
    margin-bottom: 22px;
    animation: fadeUp 0.8s 0.24s ease-out both;
  }
  .meta-chip {
    display: inline-flex; align-items: center; gap: 6px;
    font-size: 11px; font-weight: 500; color: var(--muted);
    padding: 5px 11px; border-radius: 999px;
    background: rgba(255,255,255,0.025); border: 1px solid var(--line);
  }
  .meta-chip .swatch { width: 6px; height: 6px; border-radius: 50%; }

  /* Hero socials row */
  .hero-socials {
    display: flex; flex-wrap: wrap; gap: 6px; justify-content: center;
    animation: fadeUp 0.8s 0.32s ease-out both;
  }

  /* ── Hero: VS Code-style window (sidebar + editor) ───────────────────
     The whole hero is one window. Sidebar lists every app as a file
     grouped by status; editor shows the flagship "open" with its
     mock product output. Reads as a developer's workspace, not a
     marketing tile grid. */
  .vscode-hero {
    margin-top: 28px;
    background: #0d1117;
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 14px;
    overflow: hidden;
    font-family: 'JetBrains Mono', ui-monospace, monospace;
    box-shadow: 0 30px 60px -20px rgba(0, 0, 0, 0.6);
    animation: fadeUp 0.8s 0.24s ease-out both;
  }
  /* Top chrome: traffic lights + path/title */
  .vscode-chrome {
    display: flex; align-items: center; gap: 14px;
    padding: 10px 16px;
    background: #161b22;
    border-bottom: 1px solid rgba(255, 255, 255, 0.05);
  }
  .vscode-lights { display: inline-flex; gap: 6px; }
  .vscode-lights span { width: 11px; height: 11px; border-radius: 50%; }
  .vscode-lights span:nth-child(1) { background: #ff5f57; }
  .vscode-lights span:nth-child(2) { background: #febc2e; }
  .vscode-lights span:nth-child(3) { background: #28c840; }
  .vscode-title {
    flex: 1; text-align: center;
    font-size: 11.5px; font-weight: 600;
    color: rgba(255, 255, 255, 0.55);
    letter-spacing: 0.02em;
  }

  .vscode-body {
    display: grid;
    grid-template-columns: 220px 1fr;
    min-height: 520px;
  }
  @media (max-width: 760px) { .vscode-body { grid-template-columns: 1fr; } }

  /* Left: sidebar file tree */
  .vscode-sidebar {
    background: #0a0e14;
    border-right: 1px solid rgba(255, 255, 255, 0.05);
    padding: 12px 0 16px;
    overflow-y: auto;
  }
  @media (max-width: 760px) {
    .vscode-sidebar { border-right: none; border-bottom: 1px solid rgba(255,255,255,0.05); }
  }
  .vscode-section { margin-bottom: 12px; }
  .vscode-section-label {
    display: flex; align-items: center; gap: 6px;
    padding: 6px 14px;
    font-size: 10px; font-weight: 800;
    letter-spacing: 0.16em; text-transform: uppercase;
    color: rgba(255, 255, 255, 0.45);
  }
  .vscode-section-label .chev { font-size: 9px; }
  .vscode-section-label .count { color: rgba(255, 255, 255, 0.3); font-weight: 600; letter-spacing: 0.04em; }
  .vscode-file {
    --pc: var(--text);
    display: flex; align-items: center; gap: 8px;
    padding: 5px 14px 5px 22px;
    font-size: 12.5px;
    color: rgba(255, 255, 255, 0.78);
    text-decoration: none;
    transition: background 0.15s, color 0.15s;
    border-left: 2px solid transparent;
  }
  .vscode-file:hover {
    background: rgba(255, 255, 255, 0.04);
    color: #fff;
  }
  .vscode-file.is-active {
    background: color-mix(in srgb, var(--pc) 14%, transparent);
    color: #fff;
    border-left-color: var(--pc);
  }
  .vscode-file-mark {
    width: 8px; height: 8px; border-radius: 50%;
    background: var(--pc);
    box-shadow: 0 0 8px var(--pc);
    flex-shrink: 0;
  }
  .vscode-file.is-closed { color: rgba(255, 255, 255, 0.4); }
  .vscode-file.is-closed .vscode-file-mark {
    background: rgba(255, 255, 255, 0.25);
    box-shadow: none;
  }
  .vscode-file.is-oss .vscode-file-mark {
    background: #67e8f9;
    box-shadow: 0 0 8px #67e8f9;
  }

  /* Right: editor area */
  .vscode-editor {
    display: flex; flex-direction: column;
    background: #0d1117;
    min-width: 0;
  }
  .vscode-tabs {
    display: flex;
    background: #161b22;
    border-bottom: 1px solid rgba(255, 255, 255, 0.05);
    padding: 0 8px;
  }
  .vscode-tab {
    display: inline-flex; align-items: center; gap: 8px;
    padding: 9px 14px;
    font-size: 12px; font-weight: 600;
    color: #fff;
    background: #0d1117;
    border-top: 2px solid var(--pc, #7c5cff);
    border-right: 1px solid rgba(255, 255, 255, 0.05);
  }
  .vscode-tab .x {
    color: rgba(255, 255, 255, 0.35);
    font-size: 14px; line-height: 1;
  }
  .vscode-tab .dot {
    width: 8px; height: 8px; border-radius: 50%;
    background: var(--pc, #7c5cff);
    box-shadow: 0 0 8px var(--pc, #7c5cff);
  }
  .vscode-content {
    flex: 1;
    padding: 28px 32px;
    display: flex; flex-direction: column;
    gap: 18px;
  }
  .vscode-content .h1 {
    font-family: 'Lexend', sans-serif;
    font-size: clamp(28px, 3.8vw, 40px);
    font-weight: 900;
    letter-spacing: -0.028em;
    line-height: 1;
    color: #fff;
  }
  .vscode-content .h1 .tld {
    color: rgba(255, 255, 255, 0.45); font-weight: 500;
  }
  .vscode-content .tag {
    font-size: 11px; font-weight: 700;
    letter-spacing: 0.14em; text-transform: uppercase;
    color: var(--pc, #7c5cff);
  }
  .vscode-content .term-block {
    background: rgba(0, 0, 0, 0.45);
    border: 1px solid rgba(255, 255, 255, 0.05);
    border-radius: 10px;
    padding: 14px 18px;
    font-size: 13px; line-height: 1.75;
  }
  .vscode-content .term-block .l { display: block; }
  .vscode-content .term-block .prompt { color: rgba(255,255,255,0.4); margin-right: 6px; }
  .vscode-content .term-block .cmd    { color: rgba(255,255,255,0.95); }
  .vscode-content .term-block .warn   { color: #fbbf24; }
  .vscode-content .term-block .ok     { color: #34d399; }
  .vscode-content .term-block .dim    { color: rgba(255,255,255,0.35); }
  .vscode-content .desc {
    font-family: 'Lexend', sans-serif;
    font-size: 14.5px; line-height: 1.6;
    color: rgba(255, 255, 255, 0.7);
  }
  .vscode-content .desc strong { color: #fff; font-weight: 600; }
  .vscode-content .cta {
    display: inline-flex; align-items: center; gap: 8px;
    align-self: flex-start;
    margin-top: auto;
    padding: 10px 18px;
    border-radius: 999px;
    background: var(--pc, #7c5cff);
    color: #fff;
    font-family: 'Lexend', sans-serif;
    font-size: 13px; font-weight: 700;
    letter-spacing: 0.02em;
    text-decoration: none;
    box-shadow: 0 8px 20px -6px var(--pc, #7c5cff);
    transition: transform 0.2s, box-shadow 0.2s;
  }
  .vscode-content .cta:hover {
    transform: translateY(-2px);
    box-shadow: 0 12px 26px -6px var(--pc, #7c5cff);
  }
  .vscode-content .cta svg { width: 13px; height: 13px; }

  /* ── App card: two-zone design (colored header + dark terminal body) ─── */
  .app-card {
    --pc: var(--text);
    position: relative; overflow: hidden;
    display: flex; flex-direction: column;
    background: var(--surface);
    border: 1px solid var(--line);
    border-radius: 16px;
    text-decoration: none;
    transition: border-color 0.25s, transform 0.25s, box-shadow 0.25s;
    min-height: 240px;
  }
  .app-card:hover {
    border-color: color-mix(in srgb, var(--pc) 55%, var(--line));
    transform: translateY(-3px);
    box-shadow: 0 16px 32px -12px color-mix(in srgb, var(--pc) 50%, transparent);
  }

  /* ── Top zone: colored header with bold brand presence ───────── */
  .app-card-header {
    position: relative;
    padding: 16px 16px 14px;
    background:
      radial-gradient(circle at 100% 0%, color-mix(in srgb, var(--pc) 65%, transparent) 0%, transparent 70%),
      linear-gradient(135deg,
        color-mix(in srgb, var(--pc) 38%, transparent),
        color-mix(in srgb, var(--pc) 12%, transparent) 80%);
    border-bottom: 1px solid color-mix(in srgb, var(--pc) 28%, var(--line));
    overflow: hidden;
  }
  .app-card:hover .app-card-header {
    background:
      radial-gradient(circle at 100% 0%, color-mix(in srgb, var(--pc) 78%, transparent) 0%, transparent 70%),
      linear-gradient(135deg,
        color-mix(in srgb, var(--pc) 48%, transparent),
        color-mix(in srgb, var(--pc) 16%, transparent) 80%);
  }
  .app-card-top {
    position: relative; z-index: 1;
    display: flex; align-items: center; justify-content: space-between;
    margin-bottom: 10px;
  }
  .app-card-live {
    width: 7px; height: 7px; border-radius: 50%;
    background: #fff;
    box-shadow: 0 0 10px rgba(255,255,255,0.7);
    animation: pulseDot 2s infinite;
  }
  .app-card-arrow {
    width: 14px; height: 14px;
    color: rgba(255,255,255,0.65);
    transition: color 0.2s, transform 0.2s;
  }
  .app-card:hover .app-card-arrow {
    color: #fff;
    transform: translate(2px, -2px);
  }
  .app-card-name {
    position: relative; z-index: 1;
    font-size: 24px; font-weight: 900;
    letter-spacing: -0.03em; line-height: 1;
    color: #fff;
  }
  .app-card-name .tld {
    color: rgba(255, 255, 255, 0.55); font-weight: 500;
  }
  .app-card-tag {
    position: relative; z-index: 1;
    margin-top: 4px;
    font-size: 10px; font-weight: 700;
    letter-spacing: 0.12em; text-transform: uppercase;
    color: rgba(255, 255, 255, 0.78);
  }

  /* ── Bottom zone: dark terminal body with the snippet ────────── */
  .app-card-body {
    flex: 1;
    padding: 12px 14px;
    background: rgba(0, 0, 0, 0.5);
    font-family: 'JetBrains Mono', ui-monospace, monospace;
    font-size: 10.5px; line-height: 1.7;
    overflow: hidden;
    color: rgba(255, 255, 255, 0.85);
    border-top: 1px solid rgba(255, 255, 255, 0.04);
  }
  .app-card-body .l { display: block; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
  .app-card-body .prompt { color: rgba(255,255,255,0.4); margin-right: 4px; }
  .app-card-body .cmd    { color: rgba(255,255,255,0.92); }
  .app-card-body .warn   { color: #fbbf24; }
  .app-card-body .ok     { color: #34d399; }
  .app-card-body .dim    { color: rgba(255,255,255,0.38); }

  /* ── OSS feature card (currency-symbols) ─────────────────────────────
     Clearly says "this is an open-source Python library, not a SaaS":
     Python badge, OPEN SOURCE badge, MIT badge, install command,
     downloads + stars stats. Distinct from the SaaS app cards. */
  .oss-feature {
    display: grid;
    grid-template-columns: minmax(0, 1.4fr) minmax(0, 1fr);
    background: #06070d;
    border: 1px solid rgba(34, 211, 238, 0.28);
    border-radius: 18px;
    overflow: hidden;
    text-decoration: none;
    transition: border-color 0.25s, box-shadow 0.25s, transform 0.25s;
  }
  .oss-feature:hover {
    border-color: rgba(34, 211, 238, 0.55);
    transform: translateY(-2px);
    box-shadow: 0 16px 32px -14px rgba(34, 211, 238, 0.4);
  }
  @media (max-width: 540px) {
    .oss-feature { grid-template-columns: 1fr; }
  }
  .oss-feature-left {
    padding: 22px 24px;
    display: flex; flex-direction: column;
    position: relative;
  }
  .oss-badges {
    display: flex; flex-wrap: wrap; gap: 6px;
    margin-bottom: 14px;
  }
  .oss-badge {
    display: inline-flex; align-items: center; gap: 5px;
    font-size: 9.5px; font-weight: 800;
    letter-spacing: 0.12em; text-transform: uppercase;
    padding: 3px 9px; border-radius: 999px;
  }
  .oss-badge.python {
    background: rgba(53, 114, 165, 0.16);
    color: #79b8ff;
    border: 1px solid rgba(53, 114, 165, 0.42);
  }
  .oss-badge.python svg { width: 11px; height: 11px; fill: #79b8ff; }
  .oss-badge.opensource {
    background: rgba(52, 211, 153, 0.13);
    color: #34d399;
    border: 1px solid rgba(52, 211, 153, 0.3);
  }
  .oss-badge.opensource svg { width: 11px; height: 11px; fill: currentColor; }
  .oss-badge.license {
    background: rgba(255, 255, 255, 0.03);
    color: var(--muted);
    border: 1px solid var(--line);
  }
  .oss-feature-title {
    font-family: 'JetBrains Mono', ui-monospace, monospace;
    font-size: clamp(22px, 2.6vw, 28px); font-weight: 800;
    letter-spacing: -0.02em; line-height: 1.05;
    color: var(--text);
    margin-bottom: 8px;
  }
  .oss-feature-desc {
    font-size: 13px; color: var(--muted); line-height: 1.55;
    margin-bottom: 16px;
  }
  .oss-install {
    margin-top: auto;
    padding: 12px 14px;
    background: rgba(0, 0, 0, 0.5);
    border: 1px solid rgba(255, 255, 255, 0.05);
    border-radius: 8px;
    font-family: 'JetBrains Mono', ui-monospace, monospace;
    font-size: 12.5px;
  }
  .oss-install .prompt { color: rgba(255,255,255,0.4); margin-right: 6px; }
  .oss-install .cmd { color: #fff; }
  .oss-install .pkg { color: #67e8f9; font-weight: 700; }
  .oss-feature-right {
    padding: 22px 24px;
    border-left: 1px solid rgba(34, 211, 238, 0.12);
    background: rgba(34, 211, 238, 0.025);
    display: flex; flex-direction: column; justify-content: center;
    gap: 16px;
  }
  @media (max-width: 540px) {
    .oss-feature-right { border-left: none; border-top: 1px solid rgba(34, 211, 238, 0.12); flex-direction: row; }
  }
  .oss-stat-block {
    display: flex; flex-direction: column;
  }
  .oss-stat-num {
    font-family: 'JetBrains Mono', ui-monospace, monospace;
    font-size: 32px; font-weight: 900;
    letter-spacing: -0.025em; line-height: 1;
    background: linear-gradient(135deg, #a5f3fc, #22d3ee);
    -webkit-background-clip: text; background-clip: text; -webkit-text-fill-color: transparent;
  }
  .oss-stat-label {
    font-size: 9.5px; font-weight: 700;
    letter-spacing: 0.12em; text-transform: uppercase;
    color: var(--muted);
    margin-top: 6px;
  }
  .oss-feature-right .external {
    display: flex; align-items: center; gap: 5px;
    margin-top: 8px;
    font-size: 10px; font-weight: 700;
    letter-spacing: 0.1em; text-transform: uppercase;
    color: var(--muted);
    transition: color 0.2s;
  }
  .oss-feature:hover .oss-feature-right .external { color: #67e8f9; }

  /* ── Hero bottom (closed strip) ─────────────────────────────────── */
  .hero-bottom {
    display: flex; flex-direction: column;
    gap: 12px;
    margin-top: 12px;
  }
  .bento-feature .bento-app-name {
    font-size: clamp(32px, 4.6vw, 50px);
  }
  .bento-feature .bento-app-tag {
    font-size: 11px;
    margin-top: 10px;
  }
  .bento-feature .featured-desc {
    margin-top: 14px;
    font-size: 13.5px; line-height: 1.55;
    color: rgba(255,255,255,0.86);
    max-width: 360px;
  }
  .bento-feature .featured-star {
    width: 14px; height: 14px;
    color: rgba(255,255,255,0.85);
  }
  /* Smaller (1×1) app tiles: bigger name than before to fill the smaller card */
  .bento-app:not(.bento-feature) .bento-app-name {
    font-size: clamp(22px, 2.8vw, 28px);
  }
  .bento-app:not(.bento-feature) .bento-app-tag {
    font-size: 10px;
    margin-top: 4px;
  }
  .bento-app:not(.bento-feature) .bento-app-icon {
    right: -18px; bottom: -18px;
    width: 95px; height: 95px;
    color: rgba(255, 255, 255, 0.18);
  }

  /* Mouse-follow spotlight overlay — premium "depth" cue on every tile.
     JS updates --mx / --my via mousemove. */
  .bento-tile::before {
    content: ""; position: absolute; inset: 0;
    background: radial-gradient(circle 240px at var(--mx) var(--my),
                rgba(255,255,255,0.12), transparent 55%);
    pointer-events: none;
    opacity: 0;
    transition: opacity 0.35s ease;
    z-index: 3;
    mix-blend-mode: overlay;
  }
  .bento-tile:hover::before { opacity: 1; }

  /* App tiles — solid brand-color gradient + radial highlight + icon watermark */
  .bento-app {
    background:
      radial-gradient(circle at 85% 15%, color-mix(in srgb, var(--pc) 95%, white 6%) 0%, transparent 60%),
      linear-gradient(150deg,
        color-mix(in srgb, var(--pc) 70%, transparent),
        color-mix(in srgb, var(--pc) 22%, var(--bg)));
    border-color: color-mix(in srgb, var(--pc) 45%, transparent);
  }
  .bento-app::after {
    content: ""; position: absolute;
    bottom: -48px; right: -48px;
    width: 140px; height: 140px; border-radius: 50%;
    background: var(--pc); opacity: 0.32;
    filter: blur(45px); pointer-events: none;
  }
  /* Icon watermark — large faded SVG anchored bottom-right,
     intensifies + drifts on hover for character */
  .bento-app-icon {
    position: absolute;
    right: -22px; bottom: -22px;
    width: 110px; height: 110px;
    color: rgba(255, 255, 255, 0.13);
    pointer-events: none;
    z-index: 1;
    transition: transform 0.35s ease, color 0.35s ease;
  }
  .bento-app-icon svg { width: 100%; height: 100%; }
  .bento-app:hover .bento-app-icon {
    color: rgba(255, 255, 255, 0.22);
    transform: translate(-4px, -4px) rotate(-6deg);
  }
  .bento-feature .bento-app-icon {
    right: -28px; bottom: -28px;
    width: 160px; height: 160px;
    color: rgba(255, 255, 255, 0.1);
  }
  .bento-feature:hover .bento-app-icon {
    color: rgba(255, 255, 255, 0.18);
    transform: translate(-6px, -6px) rotate(-5deg);
  }
  .bento-app:hover {
    box-shadow: 0 18px 40px -12px color-mix(in srgb, var(--pc) 55%, transparent);
    border-color: color-mix(in srgb, var(--pc) 85%, transparent);
  }
  .bento-app-top {
    position: relative; z-index: 1;
    display: flex; align-items: center; justify-content: space-between;
  }
  .bento-app-top .live-dot {
    width: 7px; height: 7px; border-radius: 50%;
    background: #fff; box-shadow: 0 0 10px rgba(255,255,255,0.7);
    animation: pulseDot 2s infinite;
  }
  .bento-app-top .arrow {
    width: 16px; height: 16px;
    color: rgba(255,255,255,0.7);
    transition: transform 0.2s, color 0.2s;
  }
  .bento-app:hover .arrow {
    color: #fff;
    transform: translate(2px, -2px);
  }
  .bento-app-name {
    position: relative; z-index: 1;
    font-size: clamp(20px, 2.6vw, 26px); font-weight: 900;
    letter-spacing: -0.03em; line-height: 1.05;
    color: #fff;
  }
  .bento-app-name .tld {
    color: rgba(255,255,255,0.55); font-weight: 500;
  }
  .bento-app-tag {
    position: relative; z-index: 1;
    margin-top: 5px;
    font-size: 10.5px; font-weight: 700;
    letter-spacing: 0.08em; text-transform: uppercase;
    color: rgba(255,255,255,0.8);
  }

  /* Package tile — terminal-block aesthetic. Self-contained (no longer
     relies on the old .bento-tile wrapper). */
  .bento-package {
    position: relative; overflow: hidden;
    display: flex; flex-direction: column;
    background: #06070d;
    border: 1px solid rgba(34, 211, 238, 0.28);
    border-radius: 18px;
    padding: 0;
    font-family: 'JetBrains Mono', ui-monospace, monospace;
    text-decoration: none;
    transition: border-color 0.25s, box-shadow 0.25s, transform 0.25s;
  }
  .bento-package:hover {
    border-color: rgba(34, 211, 238, 0.7);
    box-shadow: 0 18px 40px -12px rgba(34, 211, 238, 0.4);
  }
  /* Terminal chrome bar (traffic lights + breadcrumb) */
  .term-chrome {
    display: flex; align-items: center; gap: 14px;
    padding: 8px 14px;
    background: #0c0e16;
    border-bottom: 1px solid rgba(255,255,255,0.05);
  }
  .term-lights { display: inline-flex; gap: 5px; }
  .term-lights span {
    width: 9px; height: 9px; border-radius: 50%;
  }
  .term-lights span:nth-child(1) { background: #ff5f57; }
  .term-lights span:nth-child(2) { background: #febc2e; }
  .term-lights span:nth-child(3) { background: #28c840; }
  .term-title {
    flex: 1; text-align: center;
    font-size: 10px; font-weight: 600;
    letter-spacing: 0.04em;
    color: rgba(255,255,255,0.5);
  }
  .term-body {
    flex: 1;
    display: flex; flex-direction: column; justify-content: center;
    padding: 14px 20px 16px;
    gap: 6px;
    position: relative; z-index: 1;
  }
  .term-line { font-size: 13px; line-height: 1.45; }
  .term-prompt { color: rgba(255,255,255,0.45); margin-right: 6px; }
  .term-cmd    { color: #fff; }
  .term-pkg    { color: #facc15; font-weight: 700; }
  .term-out    { color: #67e8f9; }
  .term-out .ok { color: #34d399; margin-right: 4px; }
  .term-out .big {
    font-size: 22px; font-weight: 900;
    background: linear-gradient(135deg, #a5f3fc, #67e8f9);
    -webkit-background-clip: text; background-clip: text; -webkit-text-fill-color: transparent;
    margin: 0 4px;
    vertical-align: -1px;
  }
  .term-out .dim { color: rgba(255,255,255,0.5); }
  .term-arrow {
    position: absolute; top: 14px; right: 14px;
    width: 14px; height: 14px;
    color: rgba(255,255,255,0.4);
    transition: color 0.2s, transform 0.2s;
  }
  .bento-package:hover .term-arrow {
    color: #67e8f9; transform: translate(2px, -2px);
  }
  /* Subtle scanline pattern in the terminal background */
  .term-body::before {
    content: ""; position: absolute; inset: 0;
    background-image: repeating-linear-gradient(
      0deg,
      transparent 0,
      transparent 3px,
      rgba(34, 211, 238, 0.025) 3px,
      rgba(34, 211, 238, 0.025) 4px
    );
    pointer-events: none; z-index: -1;
  }

  /* Closed strip — horizontal layout: count + label + CTA. Self-contained. */
  .bento-closed {
    position: relative; overflow: hidden;
    display: flex; flex-direction: row; align-items: center; justify-content: space-between;
    padding: 16px 26px;
    background: rgba(255,255,255,0.018);
    border: 1px solid var(--line);
    border-radius: 18px;
    text-decoration: none;
    transition: background 0.25s, border-color 0.25s;
  }
  .bento-closed:hover {
    border-color: var(--line-strong);
    background: rgba(255,255,255,0.035);
  }
  .bento-closed-l {
    display: flex; align-items: baseline; gap: 14px;
  }
  .bento-closed-num {
    font-size: 32px; font-weight: 900;
    color: rgba(255,255,255,0.4);
    letter-spacing: -0.03em; line-height: 1;
  }
  .bento-closed-label {
    font-size: 11px; font-weight: 700;
    letter-spacing: 0.14em; text-transform: uppercase;
    color: var(--muted);
  }
  .bento-closed-cta {
    display: inline-flex; align-items: center; gap: 6px;
    font-size: 11px; font-weight: 700;
    letter-spacing: 0.08em; text-transform: uppercase;
    color: var(--muted);
    transition: color 0.2s;
  }
  .bento-closed-cta svg { width: 12px; height: 12px; }
  .bento-closed:hover .bento-closed-cta { color: var(--text); }
  .bento-closed:hover .bento-closed-cta svg { transform: translate(2px, -1px); }

  @keyframes fadeUp { from { opacity: 0; transform: translateY(22px); } to { opacity: 1; transform: translateY(0); } }
  @keyframes spin { to { transform: rotate(360deg); } }

  /* ── Mobile: drop absolute positioning, stack the cards vertically ──── */
  @media (max-width: 1023px) {
    .bento-grid {
      height: auto;
      display: flex; flex-direction: column;
      gap: 12px;
    }
    .bento-tile {
      position: static !important;
      width: 100% !important;
      height: auto !important;
      min-height: 140px;
      transform: none !important;
      --rot: 0deg !important;
      --tx: 0 !important; --ty: 0 !important;
    }
    .bento-tile:hover {
      transform: translateY(-3px) !important;
    }
    .bento-feature { min-height: 200px; }
    .bento-feature .bento-app-name { font-size: 32px; }
    .bento-feature .featured-desc { display: none; }
    .term-body { padding: 14px 16px; }
    .term-line { font-size: 12px; }
    .term-out .big { font-size: 18px; }
  }

  /* Shared .social pill style — still used by the About section below */
  .social {
    display: inline-flex; align-items: center; gap: 6px;
    font-size: 12px; font-weight: 500; color: var(--muted);
    padding: 6px 11px; border-radius: 999px;
    border: 1px solid var(--line); transition: all 0.2s;
    text-decoration: none;
  }
  .social:hover { color: var(--text); border-color: var(--line-strong); background: rgba(255,255,255,0.03); transform: translateY(-1px); }
  .social svg { width: 12px; height: 12px; }

  /* ── Marquee stats strip ────────────────────────────────────────────── */
  .marquee-wrap {
    overflow: hidden;
    border-top: 1px solid var(--line);
    border-bottom: 1px solid var(--line);
    background: rgba(255,255,255,0.015);
  }
  .marquee { display: flex; gap: 44px; padding: 14px 0; animation: marqueeScroll 38s linear infinite; width: max-content; }
  .marquee-item {
    font-size: 12px; font-weight: 500; color: var(--muted);
    white-space: nowrap; display: inline-flex; align-items: center; gap: 7px;
  }
  .marquee-item .num {
    color: var(--text); font-weight: 700;
    background: linear-gradient(135deg, var(--glow1), var(--glow2));
    -webkit-background-clip: text; background-clip: text; -webkit-text-fill-color: transparent;
  }
  .marquee-dot {
    width: 4px; height: 4px; border-radius: 50%; background: var(--muted); opacity: 0.5;
  }
  @keyframes marqueeScroll { from { transform: translateX(0); } to { transform: translateX(-50%); } }

  /* ── Section scaffolding ─────────────────────────────────────────────── */
  .section { padding: 80px 24px; max-width: 820px; margin: 0 auto; }
  .section-label {
    font-size: 10px; font-weight: 700; letter-spacing: 0.16em; text-transform: uppercase;
    color: var(--glow1); text-align: center; margin-bottom: 10px;
  }
  .section h2 {
    font-size: clamp(22px, 3.4vw, 32px); font-weight: 800;
    letter-spacing: -0.025em; text-align: center; color: var(--text);
    margin-bottom: 10px; line-height: 1.15;
  }
  .section-sub {
    font-size: 14px; color: var(--muted); text-align: center;
    max-width: 500px; margin: 0 auto 40px; line-height: 1.6;
  }

  /* ── NOW: cinematic timeline ─────────────────────────────────────────── */
  .now .timeline { position: relative; }
  .now .timeline::before {
    content: ""; position: absolute; left: 25px; top: 4px; bottom: 4px; width: 2px;
    background: linear-gradient(180deg, var(--glow1), var(--glow2), var(--glow3));
    opacity: 0.22; border-radius: 2px;
  }
  .now .row {
    display: flex; gap: 18px; padding: 10px 0; margin-bottom: 18px;
    align-items: flex-start; position: relative;
  }
  .now .row:last-child { margin-bottom: 0; }
  .now .marker {
    width: 52px; height: 52px; border-radius: 14px; flex-shrink: 0;
    display: grid; place-items: center; font-size: 20px;
    background: rgba(255,255,255,0.035);
    border: 1px solid var(--line);
    position: relative; z-index: 1; transition: all 0.3s;
  }
  .now .row:hover .marker { transform: scale(1.05); border-color: var(--line-strong); }
  .now .body { padding-top: 4px; min-width: 0; }
  .now .num {
    font-size: 10px; font-weight: 700; letter-spacing: 0.12em; text-transform: uppercase;
    margin-bottom: 3px;
  }
  .now .title {
    font-size: 17px; font-weight: 700; color: var(--text);
    letter-spacing: -0.015em; margin-bottom: 4px;
  }
  .now .desc { font-size: 13.5px; color: var(--muted); line-height: 1.6; max-width: 520px; }
  .now .desc a { color: var(--text); border-bottom: 1px dashed rgba(255,255,255,0.25); }
  .now .desc a:hover { border-color: var(--text); }

  /* ── SHIPPING: mixed-span bento (Dribbble 23193374 layout) ─────────── */
  .ship-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    grid-auto-rows: 160px;
    gap: 12px;
    grid-auto-flow: dense;
  }
  .ship-card.span-wide  { grid-column: span 2; }
  .ship-card.span-tall  { grid-row:    span 2; }

  /* Every span variant should fill its grid cell vertically and distribute
     content (top row + name/tag at top, blurb pushed down). */
  .ship-grid > .ship-card {
    height: 100%;
    min-height: 0;                          /* override the legacy 188px min */
    justify-content: flex-start;
  }
  .ship-grid > .ship-card .ship-card-blurb {
    margin-top: auto;                       /* push to bottom of the card */
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    display: -webkit-box;
    overflow: hidden;
  }

  /* 1×1 small tile: drop the blurb, shrink name+tag */
  .ship-card.span-small .ship-card-blurb { display: none; }
  .ship-card.span-small .ship-card-name  { font-size: 18px; }
  .ship-card.span-small .ship-card-tag   { font-size: 10px; }

  /* 1×2 tall tile: more vertical room → show fuller blurb */
  .ship-card.span-tall .ship-card-name   { font-size: 22px; }
  .ship-card.span-tall .ship-card-blurb  { -webkit-line-clamp: 6; }

  @media (max-width: 1023px) {
    .ship-grid { grid-template-columns: repeat(2, 1fr); grid-auto-rows: 158px; }
    .ship-card.span-wide  { grid-column: span 2; }
    .ship-card.span-tall  { grid-row: span 1; }
    .ship-card.span-small { grid-column: span 1; }
  }
  @media (max-width: 540px) {
    .ship-grid { grid-template-columns: 1fr; grid-auto-rows: auto; }
    .ship-card.span-wide, .ship-card.span-tall, .ship-card.span-small {
      grid-column: span 1; grid-row: span 1; min-height: 140px;
    }
  }
  .ship-card {
    --pc: var(--text);
    position: relative; overflow: hidden;
    display: flex; flex-direction: column;
    padding: 18px 18px 16px;
    border-radius: 16px;
    background: var(--surface); border: 1px solid var(--line);
    transition: all 0.25s ease;
    text-decoration: none; color: inherit;
    min-height: 188px;
  }
  /* ambient orb — fades in on hover with the brand color */
  .ship-card::before {
    content: ""; position: absolute;
    top: -40px; right: -40px;
    width: 140px; height: 140px; border-radius: 50%;
    background: var(--pc); opacity: 0.08;
    filter: blur(28px);
    transition: opacity 0.3s, transform 0.4s;
    pointer-events: none;
  }
  /* thin colored bar along the bottom — the "brand signature" */
  .ship-card::after {
    content: ""; position: absolute;
    left: 0; right: 0; bottom: 0; height: 2px;
    background: var(--pc); opacity: 0.35;
    transition: opacity 0.25s;
  }
  .ship-card:hover {
    border-color: color-mix(in srgb, var(--pc) 30%, var(--line));
    transform: translateY(-2px);
    box-shadow: 0 12px 30px -10px color-mix(in srgb, var(--pc) 35%, transparent);
  }
  .ship-card:hover::before { opacity: 0.22; transform: scale(1.15); }
  .ship-card:hover::after { opacity: 0.85; }

  .ship-card-top {
    position: relative; z-index: 1;
    display: flex; align-items: center; justify-content: space-between;
    margin-bottom: 14px;
  }
  .ship-card .badge-live,
  .ship-card .badge-closed {
    font-size: 9px; font-weight: 700; letter-spacing: 0.1em; text-transform: uppercase;
    padding: 3px 8px; border-radius: 999px;
    display: inline-flex; align-items: center; gap: 5px;
  }
  .ship-card .badge-live {
    color: var(--green);
    background: rgba(52, 211, 153, 0.08);
    border: 1px solid rgba(52, 211, 153, 0.2);
  }
  .ship-card .badge-closed {
    color: rgba(235, 231, 245, 0.5);
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(255, 255, 255, 0.1);
  }
  .ship-card .badge-live .ld {
    width: 5px; height: 5px; border-radius: 50%;
    background: var(--green); box-shadow: 0 0 7px var(--green);
    animation: pulseDot 2s infinite;
  }
  .ship-card .badge-closed .ld {
    width: 5px; height: 5px; border-radius: 50%;
    background: rgba(235, 231, 245, 0.4);
  }

  /* Retired-apps inline strip below the bento */
  .ship-archive {
    margin-top: 18px;
    padding: 14px 18px;
    background: rgba(255, 255, 255, 0.018);
    border: 1px solid var(--line);
    border-radius: 12px;
    display: flex; flex-wrap: wrap; align-items: center; gap: 10px;
    font-size: 13px; color: var(--muted); line-height: 1.6;
  }
  .ship-archive-label {
    font-size: 10px; font-weight: 700;
    letter-spacing: 0.14em; text-transform: uppercase;
    color: rgba(255, 255, 255, 0.5);
    margin-right: 4px;
  }
  .ship-archive-name {
    color: rgba(255, 255, 255, 0.6);
    font-weight: 600;
  }
  .ship-archive-name .tld { color: rgba(255, 255, 255, 0.3); font-weight: 400; }
  .ship-archive-sep { color: rgba(255, 255, 255, 0.2); }

  /* Closed cards: muted, non-interactive, no lift on hover */
  .ship-card.is-closed {
    opacity: 0.62; cursor: default;
  }
  .ship-card.is-closed:hover {
    border-color: var(--line);
    transform: none;
    box-shadow: none;
    opacity: 0.78;
  }
  .ship-card.is-closed::before { opacity: 0.04; }
  .ship-card.is-closed:hover::before { opacity: 0.08; transform: none; }
  .ship-card.is-closed::after { opacity: 0.15; }
  .ship-card.is-closed:hover::after { opacity: 0.15; }
  /* Hide the arrow on closed cards — no destination */
  .ship-card.is-closed .ship-arrow { display: none; }
  .ship-card .ship-arrow {
    width: 24px; height: 24px; border-radius: 50%;
    display: grid; place-items: center;
    background: rgba(255,255,255,0.03);
    border: 1px solid var(--line);
    color: var(--muted);
    transition: all 0.2s;
  }
  .ship-card:hover .ship-arrow {
    background: var(--pc); border-color: transparent;
    color: #0a0710; transform: translate(2px, -2px);
  }
  .ship-card .ship-arrow svg { width: 11px; height: 11px; }

  .ship-card-name {
    position: relative; z-index: 1;
    font-size: 22px; font-weight: 800; color: var(--text);
    letter-spacing: -0.025em; line-height: 1;
    margin-bottom: 4px;
  }
  .ship-card-name .tld {
    color: var(--muted); font-weight: 500;
  }
  .ship-card-tag {
    position: relative; z-index: 1;
    display: inline-block; margin-bottom: 10px;
    font-size: 10px; font-weight: 700;
    letter-spacing: 0.08em; text-transform: uppercase;
    color: var(--pc);
  }
  .ship-card-blurb {
    position: relative; z-index: 1;
    font-size: 12.5px; color: var(--muted); line-height: 1.55;
    flex: 1;
  }

  @media (max-width: 540px) {
    .ship-grid { grid-template-columns: 1fr; }
  }
  @media (min-width: 541px) and (max-width: 820px) {
    .ship-grid { grid-template-columns: repeat(2, 1fr); }
  }

  /* ── BOUNTY: 4 profile cards ─────────────────────────────────────────── */
  .bounty-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 12px;
  }
  .bcard {
    --pc: var(--text);
    position: relative; overflow: hidden;
    display: flex; flex-direction: column; align-items: center;
    padding: 20px 14px 16px;
    border-radius: 14px;
    background: var(--surface); border: 1px solid var(--line);
    transition: all 0.25s; text-align: center;
  }
  .bcard::before {
    content: ""; position: absolute; inset: 0;
    background: radial-gradient(circle at top, var(--pc) 0%, transparent 60%);
    opacity: 0; transition: opacity 0.3s;
    pointer-events: none;
  }
  .bcard:hover { border-color: var(--pc); transform: translateY(-3px); }
  .bcard:hover::before { opacity: 0.12; }
  .bcard .pmark {
    position: relative; z-index: 1;
    width: 42px; height: 42px; border-radius: 11px;
    display: grid; place-items: center;
    color: #fff;
    background: var(--pc); border: 1px solid rgba(255,255,255,0.12);
    box-shadow: 0 5px 18px -6px var(--pc);
    margin-bottom: 10px;
  }
  .bcard .pmark svg {
    width: 22px; height: 22px;
    fill: currentColor; display: block;
  }
  .bcard .pname {
    position: relative; z-index: 1;
    font-size: 13px; font-weight: 700; color: var(--text);
    letter-spacing: -0.01em; margin-bottom: 2px;
  }
  .bcard .phandle {
    position: relative; z-index: 1;
    font-family: 'JetBrains Mono', ui-monospace, monospace;
    font-size: 11px; font-weight: 500; color: var(--muted);
    margin-bottom: 12px;
  }
  .bcard .pcta {
    position: relative; z-index: 1;
    display: inline-flex; align-items: center; gap: 5px;
    font-size: 10px; font-weight: 700; letter-spacing: 0.08em; text-transform: uppercase;
    color: var(--pca, var(--pc));   /* `--pca` = accent for readable CTA color (HackerOne falls back to white here) */
    padding: 5px 10px; border-radius: 999px;
    background: rgba(255,255,255,0.03); border: 1px solid var(--line);
    transition: all 0.2s;
  }
  .bcard:hover .pcta { border-color: var(--pca, var(--pc)); }
  .bcard .pcta svg { width: 9px; height: 9px; }

  /* ── OSS: same mixed-span bento as Shipping ────────────────────────── */
  .oss-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    grid-auto-rows: 160px;
    gap: 12px;
    grid-auto-flow: dense;
  }
  .oss-card.span-wide  { grid-column: span 2; }
  .oss-card.span-tall  { grid-row:    span 2; }

  /* Every span variant fills its cell and uses space-between so the
     downloads pill (when present) anchors to the bottom edge. */
  .oss-grid > .oss-card {
    height: 100%;
    min-height: 0;                  /* override the legacy 144px min */
    justify-content: flex-start;
  }
  .oss-grid > .oss-card .oss-card-blurb {
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    display: -webkit-box;
    overflow: hidden;
  }
  .oss-grid > .oss-card .oss-card-downloads {
    margin-top: auto;
  }

  /* 1×1 small tile: drop the blurb */
  .oss-card.span-small .oss-card-blurb { display: none; }
  .oss-card.span-small .oss-card-name  { font-size: 14px; }
  .oss-card.span-small .oss-card-lang-pill { font-size: 9px; padding: 2px 7px; }

  /* 1×2 tall tile: show more lines of blurb */
  .oss-card.span-tall .oss-card-name  { font-size: 18px; }
  .oss-card.span-tall .oss-card-blurb { -webkit-line-clamp: 6; font-size: 12.5px; }

  @media (max-width: 1023px) {
    .oss-grid { grid-template-columns: repeat(2, 1fr); grid-auto-rows: 150px; }
    .oss-card.span-wide  { grid-column: span 2; }
    .oss-card.span-tall  { grid-row:    span 1; }
    .oss-card.span-small { grid-column: span 1; }
  }
  @media (max-width: 540px) {
    .oss-grid { grid-template-columns: 1fr; grid-auto-rows: auto; }
    .oss-card.span-wide, .oss-card.span-tall, .oss-card.span-small {
      grid-column: span 1; grid-row: span 1; min-height: 130px;
    }
  }
  .oss-card {
    --lc: var(--text);
    position: relative; overflow: hidden;
    display: flex; flex-direction: column;
    padding: 16px 16px 14px;
    border-radius: 14px;
    background: var(--surface);
    border: 1px solid var(--line);
    transition: all 0.25s;
    min-width: 0;
    text-decoration: none; color: inherit;
    min-height: 144px;
  }
  .oss-card::before {
    content: ""; position: absolute;
    top: -36px; right: -36px;
    width: 120px; height: 120px; border-radius: 50%;
    background: var(--lc); opacity: 0.07;
    filter: blur(24px);
    transition: opacity 0.3s, transform 0.4s;
    pointer-events: none;
  }
  .oss-card::after {
    content: ""; position: absolute;
    left: 0; right: 0; bottom: 0; height: 2px;
    background: var(--lc); opacity: 0.3;
    transition: opacity 0.25s;
  }
  .oss-card:hover {
    border-color: color-mix(in srgb, var(--lc) 35%, var(--line));
    transform: translateY(-2px);
    box-shadow: 0 10px 24px -10px color-mix(in srgb, var(--lc) 30%, transparent);
  }
  .oss-card:hover::before { opacity: 0.18; transform: scale(1.15); }
  .oss-card:hover::after { opacity: 0.75; }

  .oss-card-top {
    position: relative; z-index: 1;
    display: flex; align-items: center; justify-content: space-between;
    gap: 8px; margin-bottom: 8px;
  }
  .oss-card-lang-pill {
    display: inline-flex; align-items: center; gap: 6px;
    font-size: 10px; font-weight: 600;
    padding: 3px 8px 3px 8px;
    border-radius: 999px;
    color: var(--lc);
    background: color-mix(in srgb, var(--lc) 10%, transparent);
    border: 1px solid color-mix(in srgb, var(--lc) 25%, transparent);
  }
  .oss-card-lang-pill .swatch {
    width: 6px; height: 6px; border-radius: 50%; background: var(--lc);
  }
  .oss-card-stars {
    flex-shrink: 0;
    font-family: 'JetBrains Mono', ui-monospace, monospace;
    font-size: 11px; font-weight: 700; color: var(--glow4);
    display: inline-flex; align-items: center; gap: 4px;
  }
  .oss-card-stars svg { width: 11px; height: 11px; }
  .oss-card-name {
    position: relative; z-index: 1;
    font-size: 16px; font-weight: 800; color: var(--text);
    letter-spacing: -0.018em; line-height: 1.15;
    margin-bottom: 4px;
    overflow: hidden; text-overflow: ellipsis; white-space: nowrap;
  }
  .oss-card-blurb {
    position: relative; z-index: 1;
    font-size: 12px; color: var(--muted); line-height: 1.5;
    margin-bottom: 0;
    flex: 1;
  }
  /* Downloads pill — appears only on cards with pypi/npm data; live-filled via shields.io. */
  .oss-card-downloads {
    position: relative; z-index: 1;
    margin-top: 10px;
    align-self: flex-start;
    display: inline-flex; align-items: center; gap: 5px;
    font-family: 'JetBrains Mono', ui-monospace, monospace;
    font-size: 10.5px; font-weight: 700;
    color: var(--green);
    background: rgba(52, 211, 153, 0.08);
    border: 1px solid rgba(52, 211, 153, 0.22);
    padding: 3px 9px; border-radius: 999px;
  }
  .oss-card-downloads svg { width: 11px; height: 11px; }
  .oss-card-downloads .num { color: var(--green); }
  .oss-card-downloads .suffix { color: var(--muted); font-weight: 600; }

  @media (max-width: 540px) {
    .oss-grid { grid-template-columns: 1fr; }
  }
  @media (min-width: 541px) and (max-width: 820px) {
    .oss-grid { grid-template-columns: repeat(2, 1fr); }
  }

  .oss-more {
    display: inline-flex; align-items: center; gap: 7px;
    margin-top: 22px;
    font-size: 12px; font-weight: 500; color: var(--muted);
    padding: 8px 14px; border-radius: 999px;
    border: 1px solid var(--line); transition: all 0.2s;
  }
  .oss-more:hover { color: var(--text); border-color: var(--line-strong); background: rgba(255,255,255,0.03); }

  /* ── ABOUT ───────────────────────────────────────────────────────────── */
  /* Replaces the old Story section + holds all the identity content that
     used to live in the hero (photo, name, role chips, social links). */
  .about { max-width: 720px; }
  .about-card {
    display: flex; align-items: center; gap: 22px;
    padding: 22px;
    background: var(--surface);
    border: 1px solid var(--line);
    border-radius: 18px;
    margin-bottom: 32px;
  }
  .about-photo-wrap {
    position: relative; flex-shrink: 0;
    width: 96px; height: 96px;
  }
  .about-photo-wrap::before {
    content: ""; position: absolute; inset: -5px; border-radius: 50%;
    background: conic-gradient(from 0deg, var(--glow1), var(--glow2), var(--glow3), var(--glow4), var(--glow1));
    opacity: 0.4; filter: blur(10px);
    animation: spin 20s linear infinite;
  }
  .about-photo {
    position: relative;
    width: 100%; height: 100%; border-radius: 50%;
    object-fit: cover;
    border: 2px solid rgba(255,255,255,0.18);
    background: var(--bg);
  }
  .about-status {
    position: absolute; bottom: 3px; right: 3px; z-index: 2;
    width: 14px; height: 14px; border-radius: 50%;
    background: var(--green); border: 2.5px solid var(--bg);
    box-shadow: 0 0 8px var(--green);
  }
  .about-info { flex: 1; min-width: 0; }
  .about-info .name {
    font-size: 22px; font-weight: 800;
    letter-spacing: -0.02em; color: var(--text);
    margin-bottom: 6px;
  }
  .about-info .tagline {
    font-size: 13px; color: var(--muted); line-height: 1.6; margin: 0 0 12px;
  }
  .about-info .tagline a { color: var(--text); border-bottom: 1px dashed rgba(255,255,255,0.25); }
  .about-info .tagline strong { color: var(--text); font-weight: 600; }
  .about-chips {
    display: flex; flex-wrap: wrap; gap: 5px; margin-bottom: 10px;
  }
  .about-chip {
    display: inline-flex; align-items: center; gap: 5px;
    font-size: 11px; font-weight: 500; color: var(--muted);
    padding: 4px 9px; border-radius: 999px;
    background: rgba(255,255,255,0.025); border: 1px solid var(--line);
  }
  .about-chip .swatch { width: 6px; height: 6px; border-radius: 50%; }
  .about-socials {
    display: flex; flex-wrap: wrap; gap: 5px;
  }

  .about-story {}
  .about-story p {
    font-size: 14.5px; line-height: 1.75; color: rgba(235, 231, 245, 0.78);
    margin-bottom: 14px;
  }
  .about-story p strong { color: var(--text); font-weight: 600; }
  .about-story p a { color: var(--text); border-bottom: 1px dashed rgba(255,255,255,0.3); }
  .about-story p a:hover { border-color: var(--text); }
  .about-story .pull {
    font-size: 15.5px; font-weight: 500; color: var(--text);
    border-left: 2px solid var(--glow1);
    padding: 6px 0 6px 16px; margin: 18px 0;
    line-height: 1.6; letter-spacing: -0.01em;
  }
  .about-story .sig-line {
    margin-top: 22px; font-size: 13.5px; color: var(--text); font-weight: 600;
  }

  @media (max-width: 540px) {
    .about-card { flex-direction: column; text-align: center; gap: 16px; padding: 20px; }
    .about-chips, .about-socials { justify-content: center; }
  }

  /* ── Floating pill footer ────────────────────────────────────────────── */
  .footer {
    position: fixed; bottom: 16px; left: 50%; transform: translateX(-50%); z-index: 100;
    display: flex; align-items: center; justify-content: space-between; gap: 14px;
    width: 92%; max-width: 940px; padding: 12px 22px;
    background: rgba(10, 7, 16, 0.62);
    backdrop-filter: blur(20px); -webkit-backdrop-filter: blur(20px);
    border: 1px solid var(--line); border-radius: 999px;
    font-size: 12px;
  }
  .footer .copy { color: var(--muted); font-weight: 500; }
  .footer .copy b { color: var(--text); font-weight: 700; }
  .footer .links { display: flex; gap: 14px; }
  .footer .links a { color: var(--muted); transition: color 0.2s; }
  .footer .links a:hover { color: var(--text); }

  /* ── Scroll reveal ───────────────────────────────────────────────────── */
  .reveal { opacity: 0; transform: translateY(34px); transition: opacity 0.7s ease-out, transform 0.7s ease-out; }
  .reveal.visible { opacity: 1; transform: translateY(0); }

  /* ── Responsive ──────────────────────────────────────────────────────── */
  /* Live-stat spans — subtle skeleton while loading */
  [data-gh-stat], [data-gh-stars-of] {
    display: inline-block; min-width: 1.5em;
    font-variant-numeric: tabular-nums;
  }
  [data-gh-stat][data-loading="true"], [data-gh-stars-of][data-loading="true"] {
    color: var(--muted); opacity: 0.6;
  }

  @media (max-width: 760px) {
    .nav { width: 94%; padding: 10px 16px; gap: 10px; }
    .nav-links { display: none; }
    .footer { width: 94%; padding: 10px 18px; flex-wrap: nowrap; }
    .footer .copy .made-by { display: none; }
    .section { padding: 80px 20px; }
    .now .timeline::before { left: 23px; }
    .now .marker { width: 48px; height: 48px; font-size: 20px; border-radius: 14px; }
    .now .title { font-size: 18px; }
    .ship-row { padding: 18px 20px; }
    .ship-row .name { font-size: 16px; }
    .oss-row { grid-template-columns: 22px 1fr; }
    .oss-row .oss-lang, .oss-row .oss-stars { grid-column: 2; padding-top: 2px; font-size: 11px; }
    .orb { opacity: 0.18; }
    .bounty-grid { grid-template-columns: repeat(2, 1fr); }
    .hero-photo-wrap { width: 80px; height: 80px; }
  }

  @media (prefers-reduced-motion: reduce) {
    .orb, .marquee, .hero-eyebrow .dot, .nav-brand .dot, .badge-live .ld, .hero h1 .gr { animation: none !important; }
    .reveal { opacity: 1; transform: none; }
  }
</style>

