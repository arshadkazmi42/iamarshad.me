          { num_html: '<span data-gh-stat="public_repos">—</span>',                           label: "public repos on GitHub" },
          { num_html: '<span data-gh-stat="followers">—</span>',                              label: "GitHub followers" },
          { num_html: '<span data-gh-stars-of="arshadkazmi42/first-issues">—</span>',         label: "stars on first-issues" },
          { num_html: bounty.length.to_s,                                                     label: "bug bounty platforms" },
