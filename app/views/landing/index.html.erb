          <span class="ship-archive-name" title="<%= app[:tag] %>"><%= app[:name] %><span class="tld"><%= app[:tld] %></span></span><% if i < closed_apps.length - 1 %><span class="ship-archive-sep">·</span><% end %>
        <% end %>
      </div>
    <% end %>
  </section>

  <!-- ───────────────────────── BOUNTY ────────────────────────── -->
  <section id="bounty" class="section bounty reveal">
