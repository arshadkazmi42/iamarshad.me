</div>

<script>
  // Scroll reveal — IntersectionObserver
  document.addEventListener("DOMContentLoaded", function () {
    var els = document.querySelectorAll(".reveal");
    if (els.length) {
      var io = new IntersectionObserver(function (entries) {
        entries.forEach(function (e) {
          if (e.isIntersecting) { e.target.classList.add("visible"); io.unobserve(e.target); }
        });
      }, { threshold: 0.1 });
      els.forEach(function (el) { io.observe(el); });
    }

    // ── Live stats: cache + validate so we never render an error ──────
    //
    // Both shields.io and the GitHub public API will sometimes return
    // garbage instead of a number (rate limits, "invalid", "unknown"…).
    //
    // Strategy:
    //   1. Render cached value instantly on page load (no flash of "—")
    //   2. Fetch fresh in the background
    //   3. Validate it's a numeric value (digits, optional decimal, optional k/M/B suffix)
    //   4. Only update the DOM if validation passed
    //   5. Persist valid values to localStorage with a 12-hour TTL
    //
    // Net: stale-but-correct beats fresh-but-broken.
    var CACHE_TTL = 12 * 60 * 60 * 1000;  // 12 hours
    var NUM_RE    = /^\d+(\.\d+)?[kMBG]?$/i;  // "931k", "175", "1.2M", "327"

    function readCache(key) {
      try {
        var raw = localStorage.getItem(key);
        if (!raw) return null;
        var obj = JSON.parse(raw);
        if (!obj || obj.value === undefined) return null;
        return obj;
      } catch (e) { return null; }
    }
    function writeCache(key, value) {
      try { localStorage.setItem(key, JSON.stringify({ value: value, ts: Date.now() })); } catch (e) {}
    }
    function setText(el, text) {
      var inner = el.querySelector(".num") || el.querySelector(".big") || el.querySelector("span");
      if (inner) inner.textContent = text;
      else el.textContent = text;
    }
    function fmtNum(n) {
      if (typeof n !== "number" || isNaN(n)) return null;
      if (n >= 1000) return (n / 1000).toFixed(n >= 10000 ? 0 : 1).replace(/\.0$/, "") + "k";
      return n.toString();
    }

    // Generic "cached live stat" wrapper.
    function wireStat(key, fetcher, els) {
      var cached = readCache(key);
      if (cached) els.forEach(function (el) { setText(el, cached.value); });
      if (cached && (Date.now() - cached.ts) < CACHE_TTL) return;  // still fresh; skip network
      fetcher()
        .then(function (value) {
          if (!value || !NUM_RE.test(value)) return;  // ← drop errors, never render them
          writeCache(key, value);
          if (!cached || cached.value !== value) {
            els.forEach(function (el) { setText(el, value); });
          }
        })
        .catch(function () { /* keep cached, never render error */ });
    }

    var GH_USER = "arshadkazmi42";

    // GitHub user-level (public_repos + followers — one request, multiple stats)
    var userStatEls = {};
    document.querySelectorAll("[data-gh-stat]").forEach(function (el) {
      var key = el.getAttribute("data-gh-stat");
      (userStatEls[key] = userStatEls[key] || []).push(el);
    });
    Object.keys(userStatEls).forEach(function (statKey) {
      wireStat("gh-user:" + GH_USER + ":" + statKey, function () {
        return fetch("https://api.github.com/users/" + GH_USER)
          .then(function (r) { return r.ok ? r.json() : null; })
          .then(function (d) { return d ? fmtNum(d[statKey]) : null; });
      }, userStatEls[statKey]);
    });

    // GitHub per-repo star counts (de-dupe by repo slug)
    var repoEls = {};
    document.querySelectorAll("[data-gh-stars-of]").forEach(function (el) {
      var slug = el.getAttribute("data-gh-stars-of");
      (repoEls[slug] = repoEls[slug] || []).push(el);
    });
    Object.keys(repoEls).forEach(function (repo) {
      wireStat("gh-stars:" + repo, function () {
        return fetch("https://api.github.com/repos/" + repo)
          .then(function (r) { return r.ok ? r.json() : null; })
          .then(function (d) { return d ? fmtNum(d.stargazers_count) : null; });
      }, repoEls[repo]);
    });

    // PyPI / npm downloads via shields.io (pre-formatted as "931k/month")
    var downloadEls = {};
    document.querySelectorAll("[data-downloads-of]").forEach(function (el) {
      var slug = el.getAttribute("data-downloads-of");
      (downloadEls[slug] = downloadEls[slug] || []).push(el);
    });
    Object.keys(downloadEls).forEach(function (slug) {
      wireStat("dl:" + slug, function () {
        return fetch("https://img.shields.io/" + slug.replace("/", "/dm/") + ".json")
          .then(function (r) { return r.ok ? r.json() : null; })
          .then(function (d) {
            if (!d || !d.message) return null;
            return d.message.replace(/\/(month|week|day)$/i, "").trim();
          });
      }, downloadEls[slug]);
    });

    // ── Bento mouse-follow spotlight + scatter parallax ───────────────
    (function () {
      if (window.matchMedia && window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;

      // Mouse-tracking spotlight on rich cards (driven by --mx/--my).
      document.querySelectorAll('.app-card, .oss-card, .ship-card').forEach(function (tile) {
        tile.addEventListener('mousemove', function (e) {
          var r = tile.getBoundingClientRect();
          tile.style.setProperty('--mx', (e.clientX - r.left) + 'px');
          tile.style.setProperty('--my', (e.clientY - r.top) + 'px');
        });
      });
    })();
  });
</script>
