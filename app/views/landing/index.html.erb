<% content_for :title, "Arshad Kazmi — indie hacker, bug bounty hunter, software engineer" %>
<% content_for :meta_description, "Personal site of Arshad Kazmi. I build the i*.today indie SaaS suite, hunt bugs as @codermak, and write software at Smartly.io. Based in Berlin." %>
<% content_for :meta_keywords, "Arshad Kazmi, arshadkazmi42, codermak, indie hacker portfolio, bug bounty hunter, software engineer Berlin, iScan, iSsl, iLink, GhRev" %>

