<% logo_svg ||= '' %>
<header class="fixed top-0 left-0 right-0 z-50">
  <div class="absolute inset-0 bg-[#0a0a0f]/80 backdrop-blur-xl border-b border-white/5"></div>
  <div class="absolute inset-0 bg-gradient-to-b from-[#7c5cff]/5 to-transparent pointer-events-none"></div>

  <nav class="relative max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-4">
    <div class="flex justify-between items-center">
      <%= link_to root_path, class: "flex items-center gap-2.5 group relative z-10" do %>
        <div class="relative w-9 h-9 rounded-xl bg-gradient-to-br from-[#7c5cff] via-[#5b8def] to-[#22d3ee] p-2 shadow-lg shadow-[#7c5cff]/30 group-hover:shadow-[#7c5cff]/50 transition-shadow">
          <div class="text-white"><%= logo_svg.html_safe %></div>
        </div>
        <span class="text-xl font-bold text-white tracking-tight lowercase">iam<span class="text-zinc-500">.today</span></span>
      <% end %>

      <div class="hidden md:flex items-center gap-1">
        <a href="#shipping"   class="px-3 py-2 text-zinc-400 hover:text-white transition-colors text-sm font-medium">Shipping</a>
        <a href="#bounty"     class="px-3 py-2 text-zinc-400 hover:text-white transition-colors text-sm font-medium">Bug Bounty</a>
        <a href="#oss"        class="px-3 py-2 text-zinc-400 hover:text-white transition-colors text-sm font-medium">Open Source</a>
        <a href="#work"       class="px-3 py-2 text-zinc-400 hover:text-white transition-colors text-sm font-medium">Work</a>
        <a href="#about"      class="px-3 py-2 text-zinc-400 hover:text-white transition-colors text-sm font-medium">About</a>

        <a href="https://github.com/arshadkazmi42" target="_blank" rel="noopener"
           class="ml-2 px-3 py-2 text-zinc-400 hover:text-white transition-colors flex items-center gap-1.5 text-sm font-medium">
          <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.4 3-.405 1.02.005 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12"/></svg>
          GitHub
        </a>

        <a href="#contact"
           class="ml-3 inline-flex items-center gap-1.5 px-4 py-2 rounded-lg bg-gradient-to-r from-[#7c5cff] via-[#5b8def] to-[#22d3ee] text-white font-semibold text-sm shadow-lg shadow-[#7c5cff]/30 hover:shadow-[#7c5cff]/50 hover:scale-[1.03] transition-all">
          Get in touch
        </a>
      </div>

      <div class="md:hidden">
        <a href="#contact"
           class="inline-flex items-center px-3 py-1.5 rounded-lg bg-gradient-to-r from-[#7c5cff] to-[#22d3ee] text-white text-xs font-semibold">
          Get in touch
        </a>
      </div>
    </div>
  </nav>
</header>
