<% logo_svg ||= '' %>
<footer class="relative px-4 sm:px-6 lg:px-8 pt-16 pb-10 border-t border-white/5" itemscope itemtype="https://schema.org/WPFooter">
  <div class="max-w-6xl mx-auto">

    <div class="grid lg:grid-cols-5 gap-10 mb-12">
      <div class="lg:col-span-2">
        <%= link_to root_path, class: "inline-flex items-center gap-2.5 mb-5", rel: "home", "aria-label": "iamarshad.me home" do %>
          <div class="w-9 h-9 rounded-xl bg-gradient-to-br from-[#7c5cff] via-[#5b8def] to-[#22d3ee] p-2 shadow-lg shadow-[#7c5cff]/30">
            <div class="text-white"><%= logo_svg.html_safe %></div>
          </div>
          <span class="text-xl font-bold text-white tracking-tight lowercase">iam<span class="text-zinc-500">.today</span></span>
        <% end %>
        <p class="text-sm text-zinc-400 leading-relaxed max-w-md">
          The personal site of <strong class="text-zinc-200 font-medium">Arshad Kazmi</strong> — indie hacker shipping the <strong class="text-zinc-200 font-medium">i*.today</strong> suite, bug bounty hunter as <strong class="text-zinc-200 font-medium">@codermak</strong>, and software engineer at <strong class="text-zinc-200 font-medium">Smartly.io</strong>, Berlin.
        </p>

        <address class="not-italic mt-6 flex flex-wrap items-center gap-2 text-sm">
          <a href="mailto:arshadkazmi42@gmail.com" class="inline-flex items-center gap-2 px-3 py-1.5 rounded-lg bg-white/[0.04] border border-white/10 text-zinc-300 hover:bg-white/[0.07] hover:border-white/20 transition-colors" rel="noopener" itemprop="email">
            <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M3 8l9 6 9-6M5 19h14a2 2 0 0 0 2-2V7a2 2 0 0 0-2-2H5a2 2 0 0 0-2 2v10a2 2 0 0 0 2 2z"/></svg>
            arshadkazmi42@gmail.com
          </a>
        </address>
      </div>

      <!-- Browse -->
      <nav aria-label="Browse" class="lg:col-span-1">
        <h4 class="text-xs font-semibold uppercase tracking-widest text-zinc-500 mb-4">Browse</h4>
        <ul class="space-y-2.5 text-sm">
          <li><a href="#shipping" class="text-zinc-400 hover:text-white transition-colors">Shipping</a></li>
          <li><a href="#bounty"   class="text-zinc-400 hover:text-white transition-colors">Bug bounty</a></li>
          <li><a href="#oss"      class="text-zinc-400 hover:text-white transition-colors">Open source</a></li>
          <li><a href="#work"     class="text-zinc-400 hover:text-white transition-colors">Day job</a></li>
          <li><a href="#about"    class="text-zinc-400 hover:text-white transition-colors">About</a></li>
          <li><a href="#contact"  class="text-zinc-400 hover:text-white transition-colors">Contact</a></li>
        </ul>
      </nav>

      <!-- Live apps -->
