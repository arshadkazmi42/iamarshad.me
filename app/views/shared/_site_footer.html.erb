          <li><a href="https://www.linkedin.com/in/arshadkazmi42" target="_blank" rel="noopener" class="text-zinc-400 hover:text-white transition-colors">LinkedIn</a></li>
          <li><a href="https://hackerone.com/codermak" target="_blank" rel="noopener" class="text-zinc-400 hover:text-white transition-colors">HackerOne</a></li>
