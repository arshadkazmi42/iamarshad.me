        <h4 class="text-xs font-semibold uppercase tracking-widest text-zinc-500 mb-4">Live apps</h4>
        <ul class="space-y-2.5 text-sm">
          <li><a href="https://iscan.today"      target="_blank" rel="noopener" class="text-zinc-400 hover:text-white transition-colors">iScan.today</a></li>
          <li><a href="https://ispy.today"       target="_blank" rel="noopener" class="text-zinc-400 hover:text-white transition-colors">iSpy.today</a></li>
