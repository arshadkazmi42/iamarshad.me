      </nav>
    </div>

    <div class="mt-8 pt-6 border-t border-white/5 flex flex-col md:flex-row items-center justify-between gap-4 text-xs text-zinc-500">
      <div>&copy; <%= Date.current.year %> <span itemprop="name">Arshad Kazmi</span>. Built solo in Berlin.</div>
      <div class="flex items-center gap-2">
        Find me on
        <a href="https://twitter.com/arshadkazmi42" target="_blank" rel="noopener" class="text-zinc-400 hover:text-white transition-colors" itemprop="author">@arshadkazmi42</a>
      </div>
    </div>
  </div>

  <!-- Structured data for search engines -->
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@graph": [
      {
        "@type": "Person",
        "@id": "https://iamarshad.me/#person",
        "name": "Arshad Kazmi",
        "url": "https://iamarshad.me",
        "image": "https://iamarshad.me/assets/og.png",
        "jobTitle": "Software Engineer",
        "worksFor": { "@type": "Organization", "name": "Smartly.io", "url": "https://smartly.io" },
        "address": { "@type": "PostalAddress", "addressLocality": "Berlin", "addressCountry": "DE" },
        "sameAs": [
          "https://github.com/arshadkazmi42",
          "https://twitter.com/arshadkazmi42",
          "https://www.linkedin.com/in/arshadkazmi42",
          "https://hackerone.com/codermak",
          "https://bugcrowd.com/h/codermak",
          "https://app.intigriti.com/profile/codermak",
          "https://yeswehack.com/hunters/codermak"
        ],
        "knowsAbout": ["Bug Bounty", "Application Security", "Indie SaaS", "Ruby on Rails", "Chrome Extensions"]
      },
      {
        "@type": "WebSite",
        "@id": "https://iamarshad.me/#website",
        "url": "https://iamarshad.me",
        "name": "iamarshad.me",
        "description": "Personal site of Arshad Kazmi — indie hacker, bug bounty hunter as @codermak, software engineer at Smartly.io.",
        "publisher": { "@id": "https://iamarshad.me/#person" }
